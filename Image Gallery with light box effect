<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Neon Gallery - Photographer Portfolio</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --neon-cyan: #00f5ff;
            --neon-magenta: #ff00ff;
            --neon-lime: #39ff14;
            --bg-dark: #0a0a0a;
            --glass-bg: rgba(255, 255, 255, 0.1);
            --glass-border: rgba(0, 245, 255, 0.3);
            --text-light: #ffffff;
            --text-glow: #00f5ff;
            --glow-cyan: 0 0 30px #00f5ff;
            --glow-magenta: 0 0 30px #ff00ff;
            --glow-lime: 0 0 30px #39ff14;
        }

        body {
            font-family: 'Arial', sans-serif;
            background: var(--bg-dark);
            color: var(--text-light);
            overflow-x: hidden;
            position: relative;
        }

        /* Particle Background */
        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: 
                radial-gradient(2px 2px at 20px 30px, #00f5ff, transparent),
                radial-gradient(2px 2px at 40px 70px, #ff00ff, transparent),
                radial-gradient(1px 1px at 90px 40px, #39ff14, transparent),
                radial-gradient(1px 1px at 130px 80px, #00f5ff, transparent);
            background-repeat: repeat;
            background-size: 200px 100px;
            animation: float 20s linear infinite;
            z-index: -2;
            opacity: 0.3;
        }

        @keyframes float {
            0% { transform: translateY(0px) rotate(0deg); }
            100% { transform: translateY(-20px) rotate(360deg); }
        }

        .navbar {
            position: fixed;
            top: 0;
            width: 100%;
            padding: 20px 50px;
            background: rgba(10, 10, 10, 0.9);
            backdrop-filter: blur(20px);
            z-index: 1000;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            font-size: 1.8rem;
            font-weight: bold;
            background: linear-gradient(45deg, var(--neon-cyan), var(--neon-magenta));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .nav-links {
            display: flex;
            gap: 30px;
        }

        .nav-links a {
            color: var(--text-light);
            text-decoration: none;
            font-weight: 500;
            position: relative;
            transition: color 0.3s;
        }

        .nav-links a:hover {
            color: var(--neon-cyan);
            text-shadow: var(--glow-cyan);
        }

        .hero {
            height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            padding: 0 20px;
            position: relative;
        }

        .hero h1 {
            font-size: clamp(3rem, 8vw, 6rem);
            font-weight: 900;
            margin-bottom: 20px;
            background: linear-gradient(45deg, var(--neon-cyan), var(--neon-magenta), var(--neon-lime));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: glow 2s ease-in-out infinite alternate;
        }

        @keyframes glow {
            from { filter: drop-shadow(0 0 20px var(--neon-cyan)); }
            to { filter: drop-shadow(0 0 30px var(--neon-magenta)); }
        }

        .hero p {
            font-size: 1.5rem;
            max-width: 600px;
            margin-bottom: 40px;
            opacity: 0.9;
        }

        .cta-btn {
            padding: 18px 40px;
            font-size: 1.2rem;
            font-weight: bold;
            background: linear-gradient(45deg, var(--neon-cyan), var(--neon-magenta));
            border: none;
            border-radius: 50px;
            color: var(--bg-dark);
            cursor: pointer;
            transition: all 0.3s;
            box-shadow: var(--glow-cyan);
            text-decoration: none;
        }

        .cta-btn:hover {
            transform: translateY(-5px) scale(1.05);
            box-shadow: var(--glow-magenta);
        }

        .gallery-section {
            padding: 120px 50px 80px;
            max-width: 1400px;
            margin: 0 auto;
        }

        .section-title {
            text-align: center;
            font-size: 3.5rem;
            font-weight: 900;
            margin-bottom: 80px;
            background: linear-gradient(45deg, var(--neon-lime), var(--neon-cyan));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .gallery-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 30px;
            max-width: 1200px;
            margin: 0 auto;
        }

        .gallery-item {
            position: relative;
            aspect-ratio: 1;
            border-radius: 20px;
            overflow: hidden;
            cursor: pointer;
            transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
            box-shadow: 0 20px 40px rgba(0,0,0,0.3);
            backdrop-filter: blur(10px);
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
        }

        .gallery-item::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(45deg, rgba(0,245,255,0.1), rgba(255,0,255,0.1));
            opacity: 0;
            transition: opacity 0.3s;
            z-index: 2;
        }

        .gallery-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.4s;
        }

        /* Image loading placeholder */
        .gallery-item img[src=""] {
            opacity: 0;
        }

        .gallery-item img.loaded {
            opacity: 1;
        }

        .gallery-item:hover {
            transform: translateY(-15px) scale(1.02);
            box-shadow: var(--glow-cyan), 0 30px 60px rgba(0,0,0,0.5);
        }

        .gallery-item:hover::before {
            opacity: 1;
        }

        .gallery-item:hover img {
            transform: scale(1.1);
        }

        .gallery-title {
            position: absolute;
            bottom: 20px;
            left: 20px;
            right: 20px;
            background: rgba(0,0,0,0.7);
            color: white;
            padding: 15px 20px;
            border-radius: 15px;
            opacity: 0;
            transform: translateY(20px);
            transition: all 0.3s;
            font-weight: 600;
            text-align: center;
            z-index: 3;
        }

        .gallery-item:hover .gallery-title {
            opacity: 1;
            transform: translateY(0);
        }

        /* Lightbox */
        .lightbox {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.95);
            backdrop-filter: blur(10px);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 2000;
            opacity: 0;
            transition: opacity 0.4s;
        }

        .lightbox.show {
            display: flex;
            opacity: 1;
        }

        .lightbox img {
            max-width: 90vw;
            max-height: 90vh;
            border-radius: 20px;
            box-shadow: var(--glow-cyan), var(--glow-magenta);
            transform: scale(0.8);
            transition: transform 0.4s;
        }

        .lightbox.show img {
            transform: scale(1);
        }

        .lightbox-nav {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            background: rgba(255,255,255,0.2);
            border: none;
            color: white;
            font-size: 3rem;
            width: 60px;
            height: 60px;
            border-radius: 50%;
            cursor: pointer;
            transition: all 0.3s;
            backdrop-filter: blur(20px);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .lightbox-nav:hover {
            background: rgba(0,245,255,0.4);
            box-shadow: var(--glow-cyan);
            transform: translateY(-50%) scale(1.1);
        }

        .lightbox-prev { left: 5%; }
        .lightbox-next { right: 5%; }

        .lightbox-close {
            position: absolute;
            top: 30px;
            right: 30px;
            background: rgba(255,255,255,0.2);
            border: none;
            color: white;
            font-size: 2rem;
            width: 50px;
            height: 50px;
            border-radius: 50%;
            cursor: pointer;
            transition: all 0.3s;
            backdrop-filter: blur(20px);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .lightbox-close:hover {
            background: rgba(255,71,87,0.4);
            box-shadow: 0 0 20px rgba(255,71,87,0.5);
        }

        .location-info {
            position: absolute;
            bottom: 50px;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(0,0,0,0.8);
            backdrop-filter: blur(20px);
            color: var(--neon-cyan);
            padding: 20px 40px;
            border-radius: 50px;
            font-size: 1.3rem;
            font-weight: 600;
            border: 2px solid var(--neon-cyan);
            box-shadow: var(--glow-cyan);
            white-space: nowrap;
        }

        /* Error fallback for images */
        .image-error {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
            color: var(--neon-cyan);
            font-size: 1rem;
            text-align: center;
            padding: 20px;
        }

        /* Responsive */
        @media (max-width: 1024px) {
            .gallery-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: 25px;
            }
        }

        @media (max-width: 768px) {
            .gallery-grid {
                grid-template-columns: 1fr;
                gap: 20px;
            }
            .navbar {
                padding: 15px 20px;
                flex-direction: column;
                gap: 10px;
            }
            .nav-links {
                gap: 20px;
            }
            .gallery-section {
                padding: 100px 20px 60px;
            }
            .lightbox-nav {
                width: 45px;
                height: 45px;
                font-size: 2rem;
            }
        }

        /* Loading Animation */
        .loading {
            opacity: 0;
            transform: translateY(50px);
            animation: fadeInUp 0.8s forwards;
        }

        @keyframes fadeInUp {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .gallery-item:nth-child(1) { animation-delay: 0.1s; }
        .gallery-item:nth-child(2) { animation-delay: 0.2s; }
        .gallery-item:nth-child(3) { animation-delay: 0.3s; }
        .gallery-item:nth-child(4) { animation-delay: 0.4s; }
        .gallery-item:nth-child(5) { animation-delay: 0.5s; }
        .gallery-item:nth-child(6) { animation-delay: 0.6s; }
        .gallery-item:nth-child(7) { animation-delay: 0.7s; }
        .gallery-item:nth-child(8) { animation-delay: 0.8s; }
        .gallery-item:nth-child(9) { animation-delay: 0.9s; }
    </style>
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar">
        <div class="logo">NEON GALLERY</div>
        <div class="nav-links">
            <a href="#home">Home</a>
            <a href="#gallery">Gallery</a>
            <a href="#about">About</a>
            <a href="#contact">Contact</a>
        </div>
    </nav>

    <!-- Hero Section -->
    <section id="home" class="hero">
        <h1>NEON VISIONS</h1>
        <p>Capturing the world's most breathtaking moments through a neon lens</p>
        <a href="#gallery" class="cta-btn">Explore Gallery</a>
    </section>

    <!-- Gallery Section -->
    <section id="gallery" class="gallery-section">
        <h2 class="section-title">Featured Collection</h2>
        <div class="gallery-grid" id="galleryGrid">
            <!-- Gallery items will be populated by JavaScript -->
        </div>
    </section>

    <!-- Lightbox -->
    <div class="lightbox" id="lightbox">
        <button class="lightbox-close" onclick="closeLightbox()">&times;</button>
        <button class="lightbox-nav lightbox-prev" onclick="navigateLightbox(-1)">&#10094;</button>
        <img id="lightboxImage" src="" alt="Lightbox Image">
        <button class="lightbox-nav lightbox-next" onclick="navigateLightbox(1)">&#10095;</button>
        <div class="location-info" id="locationInfo"></div>
    </div>

    <script>
        // Gallery data with images
        const galleryData = [
            {
                title: "Mountain Sunrise",
                location: "Patagonia, Argentina",
                url: "https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=800&q=80"
            },
            {
                title: "Ocean Waves",
                location: "Maldives",
                url: "https://images.unsplash.com/photo-1507525428034-b723cf961d3e?w=800&q=80"
            },
            {
                title: "City Lights",
                location: "Tokyo, Japan",
                url: "https://images.unsplash.com/photo-1540959733332-eab4deabeeaf?w=800&q=80"
            },
            {
                title: "Forest Mist",
                location: "Black Forest, Germany",
                url: "https://images.unsplash.com/photo-1448375240586-882707db888b?w=800&q=80"
            },
            {
                title: "Desert Dunes",
                location: "Sahara, Morocco",
                url: "https://images.unsplash.com/photo-1509316785289-025f5b846b35?w=800&q=80"
            },
            {
                title: "Aurora Borealis",
                location: "Iceland",
                url: "https://images.unsplash.com/photo-1531366936337-7c912a4589a7?w=800&q=80"
            },
            {
                title: "Urban Skyline",
                location: "New York, USA",
                url: "https://images.unsplash.com/photo-1496442226666-8d4d0e62e6e9?w=800&q=80"
            },
            {
                title: "Underwater World",
                location: "Great Barrier Reef, Australia",
                url: "https://images.unsplash.com/photo-1544551763-46a013bb70d5?w=800&q=80"
            },
            {
                title: "Northern Lights",
                location: "Tromsø, Norway",
                url: "https://images.unsplash.com/photo-1483347756197-71ef80e95f73?w=800&q=80"
            }
        ];

        let currentIndex = 0;

        // Initialize gallery
        function initGallery() {
            const grid = document.getElementById('galleryGrid');
            
            galleryData.forEach((item, index) => {
                const galleryItem = document.createElement('div');
                galleryItem.className = 'gallery-item loading';
                galleryItem.setAttribute('tabindex', '0');
                galleryItem.onclick = () => openLightbox(index);
                galleryItem.onkeydown = (e) => {
                    if (e.key === 'Enter') openLightbox(index);
                };

                const img = document.createElement('img');
                img.src = item.url;
                img.alt = `${item.title} - ${item.location}`;
                img.loading = 'lazy';
                
                // Handle image load success
                img.onload = function() {
                    this.classList.add('loaded');
                };
                
                // Handle image load error with fallback
                img.onerror = function() {
                    this.style.display = 'none';
                    const fallback = document.createElement('div');
                    fallback.className = 'image-error';
                    fallback.innerHTML = `<span>${item.title}<br><small>Image unavailable</small></span>`;
                    this.parentNode.insertBefore(fallback, this);
                };

                const title = document.createElement('div');
                title.className = 'gallery-title';
                title.textContent = item.title;

                galleryItem.appendChild(img);
                galleryItem.appendChild(title);
                grid.appendChild(galleryItem);
            });
        }

        // Lightbox functions
        function openLightbox(index) {
            currentIndex = index;
            const lightbox = document.getElementById('lightbox');
            const lightboxImg = document.getElementById('lightboxImage');
            const locationInfo = document.getElementById('locationInfo');
            
            lightboxImg.src = galleryData[index].url;
            lightboxImg.alt = `${galleryData[index].title} - ${galleryData[index].location}`;
            locationInfo.textContent = `${galleryData[index].title} - ${galleryData[index].location}`;
            
            lightbox.style.display = 'flex';
            setTimeout(() => lightbox.classList.add('show'), 10);
            document.body.style.overflow = 'hidden';
        }

        function closeLightbox() {
            const lightbox = document.getElementById('lightbox');
            lightbox.classList.remove('show');
            setTimeout(() => {
                lightbox.style.display = 'none';
                document.body.style.overflow = 'auto';
            }, 400);
        }

        function navigateLightbox(direction) {
            currentIndex = (currentIndex + direction + galleryData.length) % galleryData.length;
            const lightboxImg = document.getElementById('lightboxImage');
            const locationInfo = document.getElementById('locationInfo');
            
            lightboxImg.src = galleryData[currentIndex].url;
            lightboxImg.alt = `${galleryData[currentIndex].title} - ${galleryData[currentIndex].location}`;
            locationInfo.textContent = `${galleryData[currentIndex].title} - ${galleryData[currentIndex].location}`;
        }

        // Keyboard navigation
        document.addEventListener('keydown', (e) => {
            const lightbox = document.getElementById('lightbox');
            if (lightbox.classList.contains('show')) {
                if (e.key === 'Escape') closeLightbox();
                if (e.key === 'ArrowLeft') navigateLightbox(-1);
                if (e.key === 'ArrowRight') navigateLightbox(1);
            }
        });

        // Close lightbox on background click
        document.getElementById('lightbox').addEventListener('click', (e) => {
            if (e.target.id === 'lightbox') closeLightbox();
        });

        // Initialize on page load
        document.addEventListener('DOMContentLoaded', initGallery);
    </script>
</body>
</html>
